<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Primary Meta Tags -->
  <title>{{ title }} | Sumit Kumar Pandit</title>
  <meta name="title" content="{{ title }} | Sumit Kumar Pandit">
  <meta name="description" content="{{ description or 'Spiritual teacher guiding seekers on the path of Self-Realization through Vedanta, Yoga and Meditation. Weekly group meditation every Sunday at 6 PM IST.' }}">
  <meta name="author" content="Sumit Kumar Pandit">
  <meta name="robots" content="index, follow">
  <meta name="language" content="English">
  <meta name="revisit-after" content="7 days">
  
  <!-- Canonical URL -->
  <link rel="canonical" href="https://sumitkpandit.github.io{{ page.url }}">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://sumitkpandit.github.io{{ page.url }}">
  <meta property="og:title" content="{{ title }} | Sumit Kumar Pandit">
  <meta property="og:description" content="{{ description or 'Spiritual teacher guiding seekers on the path of Self-Realization through Vedanta, Yoga and Meditation.' }}">
  <meta property="og:image" content="https://sumitkpandit.github.io/og-image.png">
  <meta property="og:site_name" content="Sumit Kumar Pandit">
  <meta property="og:locale" content="en_US">
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://sumitkpandit.github.io{{ page.url }}">
  <meta property="twitter:title" content="{{ title }} | Sumit Kumar Pandit">
  <meta property="twitter:description" content="{{ description or 'Spiritual teacher guiding seekers on the path of Self-Realization through Vedanta, Yoga and Meditation.' }}">
  <meta property="twitter:image" content="https://sumitkpandit.github.io/og-image.png">
  
  <!-- Keywords for SEO -->
  <meta name="keywords" content="Vedanta, Yoga, Meditation, Self-Realization, Spiritual Teacher, Guru, Mindfulness, Indian Philosophy, Non-duality, Atman, Brahman, Moksha, Raja Yoga, Bhakti Yoga, Jnana Yoga, Karma Yoga, Pranayama, Breathwork, Sadhana, Spiritual Journey, Consciousness, Enlightenment, Awakening, Sunday Meditation, Online Meditation, Guided Meditation, Meditation Teacher, Yoga Teacher, Bengaluru, India">
  
  <!-- Theme Color -->
  <meta name="theme-color" content="#2660A4">
  
  <!-- Google Fonts: EB Garamond for headings, Montserrat fallback for Gotham -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <!-- Feather Icons -->
  <script src="https://unpkg.com/feather-icons"></script>
  
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Sumit Kumar Pandit",
    "url": "https://sumitkpandit.github.io",
    "jobTitle": "Spiritual Teacher",
    "description": "Spiritual teacher guiding seekers on the path of Self-Realization through Vedanta, Yoga and Meditation",
    "sameAs": [
      "https://www.youtube.com/@sumitkpandityt",
      "https://www.instagram.com/sumitkpandit/",
      "https://x.com/sumitkpandit"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "Onclusive"
    },
    "knowsAbout": ["Vedanta", "Yoga", "Meditation", "Self-Inquiry", "Non-duality", "Raja Yoga", "Bhakti Yoga", "Jnana Yoga", "Karma Yoga"]
  }
  </script>
  
  <!-- Website Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sumit Kumar Pandit - Spiritual Teacher",
    "url": "https://sumitkpandit.github.io",
    "description": "Spiritual teacher guiding seekers on the path of Self-Realization through Vedanta, Yoga and Meditation",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://sumitkpandit.github.io/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  
  <!-- Organization Schema for Teaching Services -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Sumit Kumar Pandit - Meditation Teaching",
    "url": "https://sumitkpandit.github.io",
    "description": "Vedanta, Yoga and Meditation teachings and sessions",
    "areaServed": {
      "@type": "City",
      "name": "Bengaluru"
    },
    "serviceType": ["Online Meditation Sessions", "One-on-One Sessions", "Yoga Teaching"],
    "inLanguage": "en",
    "priceRange": "$$"
  }
  </script>
  
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  {% include "components/header.njk" %}
  
  {{ content | safe }}
  
  {% include "components/footer.njk" %}
  
  <script>
    feather.replace();
  </script>
</body>
</html>
